# Local development only.
# Copy to app/.env.local when running `npm run dev` and choose which deployed
# environment your local app should talk to. Most work should target non-prod.
#
# For release deploys, do not edit this file. Generate app/.env.prod and
# app/.env.nonprod with `npm run env:setup` instead.

# Recommended local target: copy values from app/.env.nonprod
VITE_S3_BUCKET_NAME=
VITE_S3_WEBSITE_URL=
