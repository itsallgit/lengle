# App environment variables — copy this file to .env.local and fill in values from CDK outputs.
# Never commit .env.local to git.

# S3 bucket name (CDK output: BucketName)
VITE_S3_BUCKET_NAME=

# S3 static website URL for reads, e.g. http://lengle-bucket.s3-website-ap-southeast-2.amazonaws.com (CDK output: WebsiteUrl)
VITE_S3_WEBSITE_URL=

# Cognito unauthenticated identity pool ID (CDK output: IdentityPoolId)
VITE_COGNITO_IDENTITY_POOL_ID=
